# FHIR Service Configuration

# Database
DATABASE_URL=postgresql://postgres:password@postgres/synthea

# Redis
REDIS_URL=redis://redis:6379

# Service URLs
SERVICE_NAME=fhir-service
SERVICE_URL=http://fhir-service:8001
SERVICE_PORT=8001

# FHIR Configuration
FHIR_BASE_URL=http://localhost:8001/
FHIR_VALIDATE_RESOURCES=true
FHIR_STRICT_MODE=false

# Performance
CONNECTION_POOL_SIZE=20
CONNECTION_MAX_OVERFLOW=10
CACHE_TTL=300
CACHE_ENABLED=true

# Search
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Environment
ENVIRONMENT=development
DEBUG=false